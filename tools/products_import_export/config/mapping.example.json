{
  "sheetName": "products",
  "match": {
    "sheetColumn": "Артикул",
    "inputAliases": ["артикул", "sku", "код", "код товара"]
  },
  "updates": [
    {
      "sheetColumn": "Наименование",
      "inputAliases": ["наименование", "название", "товар"]
    },
    {
      "sheetColumn": "Цена",
      "inputAliases": ["цена", "price"]
    },
    {
      "sheetColumn": "Ед. изм.",
      "inputAliases": ["ед изм", "единица", "unit"]
    }
  ],
  "pdfPatterns": [
    {
      "targetAlias": "артикул",
      "regex": "(?:Артикул|SKU)\\s*[:\\-]\\s*([A-Za-z0-9\\-_/]+)"
    },
    {
      "targetAlias": "наименование",
      "regex": "(?:Наименование|Название)\\s*[:\\-]\\s*(.+)"
    },
    {
      "targetAlias": "цена",
      "regex": "(?:Цена|Price)\\s*[:\\-]\\s*([0-9]+(?:[\\.,][0-9]+)?)"
    }
  ],
  "archiveMode": "processed_only"
}
