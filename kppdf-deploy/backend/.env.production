# KPPDF 3.0 — Production environment
# Скопируй на Synology как .env вместе с backend

NODE_ENV=production
PORT=3000

# MongoDB в Docker на Synology
MONGO_URI=mongodb://localhost:27017/kppdf30

# JWT — смени на свои секретные ключи!
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET_STRING
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_TO_ANOTHER_RANDOM_STRING
JWT_REFRESH_EXPIRES_IN=7d

# CORS — через запятую, если несколько доменов
CORS_ORIGIN=https://sport-set.ru
