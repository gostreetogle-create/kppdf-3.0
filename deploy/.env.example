# KPPDF 3.0 — конфиг деплоя
# Скопируйте в deploy/.env и заполните свои значения
#
# Генерация JWT_SECRET:
#   openssl rand -hex 32
#
# Генерация JWT_REFRESH_SECRET:
#   openssl rand -hex 32

# --- Сервер ---
DEPLOY_HOST=192.168.1.46
DEPLOY_USER=tiit
DEPLOY_PASSWORD=CHANGE_ME

# --- Пути на сервере ---
REMOTE_DIR=/opt/kppdf-3.0
KPPDF_DATA_DIR=/var/lib/kppdf

# --- Секреты (обязательно смените!) ---
JWT_SECRET=CHANGE_ME_generate_random_hex_64_chars
JWT_REFRESH_SECRET=CHANGE_ME_generate_random_hex_64_chars

# --- Домен (CORS) ---
CORS_ORIGIN=https://sport-set.ru

# --- Telegram алерты (опционально) ---
# Создай бота: @BotFather → /newbot
# Узнай chat ID: @userinfobot
#TELEGRAM_BOT_TOKEN=1234567890:ABCdef...
#TELEGRAM_CHAT_ID=123456789
