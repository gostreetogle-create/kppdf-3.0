# KPPDF 3.0 — конфиг деплоя (скопируй в config.env и заполни)
# cp deploy/synology/config.env.example deploy/synology/config.env

# --- Платформа ---
# ubuntu  — чистый Ubuntu-сервер (Docker из apt)
# synology — Synology NAS DSM 7+ (Container Manager)
PLATFORM=ubuntu

# --- SSH ---
DEPLOY_HOST=192.168.1.134
DEPLOY_USER=ubuntu
# DEPLOY_PASSWORD=          # опционально, если нет SSH-ключа

# --- Пути на сервере ---
# Код приложения (перезаписывается при деплое)
REMOTE_DIR=/opt/kppdf-3.0
# Данные: MongoDB + медиа + бэкапы (НЕ трогаются при обновлениях)
KPPDF_DATA_DIR=/var/lib/kppdf
# DOCKER_CMD=docker          # ubuntu default
# Synology: KPPDF_DATA_DIR=/volume1/docker/kppdf-data

# --- Секреты (обязательны для docker-compose.prod.yml) ---
# Сгенерируй: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_64_HEX
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_ANOTHER_64_HEX

# --- Домен ---
CORS_ORIGIN=https://sport-set.ru

# --- Первый деплой ---
SEED=true
